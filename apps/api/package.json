{
  "name": "@aide/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aide/auth": "workspace:*",
    "@aide/config": "workspace:*",
    "@aide/db": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "pino": "^9.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@trpc/client": "^11.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
