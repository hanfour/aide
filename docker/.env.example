# Copy to docker/.env and fill in. docker compose -f docker/docker-compose.yml
# automatically reads this file.

# Image tag to pull from ghcr.io/hanfour/aide-{api,web}. Pin to a release.
VERSION=v0.2.0

# Postgres (stay private inside the compose network)
DB_USER=aide
DB_PASSWORD=change-me-to-a-long-random-string
DB_NAME=aide

# Auth.js — MUST be ≥32 random bytes (openssl rand -base64 48)
AUTH_SECRET=REPLACE-WITH-48-BYTES-OF-RANDOMNESS

# Public URL users sign in from. Must exactly match the OAuth redirect you
# registered with each provider.
NEXTAUTH_URL=https://aide.example.com

# OAuth apps — register at each provider and paste the credentials here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# First-run bootstrap: the matching user becomes super_admin and a default
# org is created under them.
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_DEFAULT_ORG_SLUG=demo
BOOTSTRAP_DEFAULT_ORG_NAME=Demo

# Optional
LOG_LEVEL=info
WEB_PORT=3000

# ── Gateway (opt-in, Plan 4A v0.3.0+) ────────────────────────────────────────
# Only needed if you start the stack with `docker compose --profile gateway up`.
# See docs/GATEWAY.md for the full reference; docs/SELF_HOSTING.md §6 for the
# bring-up walkthrough.

# Public URL your users point their SDK at. Shown in the one-time reveal page.
# Must match the externally reachable origin your reverse proxy exposes for
# port 3002.
GATEWAY_BASE_URL=https://gateway.example.com

# Host port published for the gateway service.
GATEWAY_PORT=3002

# Secrets — 32 bytes hex each. Generate with `openssl rand -hex 32`.
# Inject via Docker secrets or a non-committed .env.secrets in production;
# never leave real values in this file. Losing API_KEY_HASH_PEPPER invalidates
# every issued API key by design.
CREDENTIAL_ENCRYPTION_KEY=
API_KEY_HASH_PEPPER=
